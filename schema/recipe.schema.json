{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ShirleyHuang11/howto/schema/recipe.schema.json",
  "title": "howto recipe frontmatter",
  "description": "Schema for the YAML frontmatter of every recipe. Required body sections (validated separately): Goal, Preconditions, Steps, Failure modes & recovery, Verification. Optional: Decision points, Variations, Safety & privacy.",
  "type": "object",
  "required": ["name", "domain", "locale", "interface", "difficulty", "est_time", "risk", "prerequisites", "status", "last_verified"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "kebab-case; must equal the filename without .md"
    },
    "domain": {
      "type": "string",
      "description": "Top-level directory; must be a key in domains.json and match the file's location"
    },
    "subdomain": {
      "type": "string",
      "description": "Required for domains that declare subdomains in domains.json (embodied, daily); must match the subdirectory"
    },
    "locale": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9-]+$"},
      "minItems": 1,
      "description": "First entry should be 'generic' unless the recipe is inherently locale-specific"
    },
    "interface": {
      "enum": ["physical", "web", "mobile-app", "phone-call", "mixed"]
    },
    "difficulty": {
      "enum": ["basic", "intermediate", "advanced"]
    },
    "est_time": {
      "type": "string",
      "pattern": "^[0-9]+(min|h|d)(-[0-9]+(min|h|d))?$"
    },
    "risk": {
      "enum": ["low", "medium", "high"],
      "description": "medium: money or identity involved; high: irreversible consequences possible"
    },
    "prerequisites": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Recipe references (domain/name) or capability tags (kebab-case)"
    },
    "status": {
      "enum": ["draft", "reviewed", "verified"],
      "description": "verified requires an agent-executability test (see CONTRIBUTING)"
    },
    "last_verified": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "objects": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Embodied only: object classes manipulated"
    },
    "affordances": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Embodied only: manipulation primitives required"
    },
    "workspace": {
      "type": "string",
      "description": "Embodied only: scene class for sim task compilation"
    },
    "safety": {
      "type": "object",
      "description": "Embodied only: physical safety annotations",
      "properties": {
        "hot_surfaces": {"type": "boolean"},
        "sharp_objects": {"type": "boolean"},
        "fragile": {"type": "array", "items": {"type": "string"}},
        "human_proximity": {"enum": ["continue", "slow", "pause"]}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"domain": {"const": "embodied"}}},
      "then": {"required": ["subdomain", "objects", "affordances", "workspace", "safety"]}
    },
    {
      "if": {"properties": {"domain": {"const": "daily"}}},
      "then": {"required": ["subdomain"]}
    }
  ]
}
